#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

echo "==> Installing system build dependencies"
packages=(build-essential ca-certificates curl git pkg-config)
missing_packages=()
for package in "${packages[@]}"; do
    if ! dpkg-query -W -f='${Status}' "$package" 2>/dev/null | grep -q 'ok installed'; then
        missing_packages+=("$package")
    fi
done
if ((${#missing_packages[@]})); then
    sudo apt-get update
    sudo DEBIAN_FRONTEND=noninteractive apt-get install -y "${missing_packages[@]}"
fi

echo "==> Configuring tool paths for login shells"
profile_marker="# django-language-server toolchain"
if [[ -f "$HOME/.bash_profile" ]]; then
    sed -i -E "s/^# django-language-server [^ ]+ toolchain( v[0-9]+)?$/$profile_marker/" "$HOME/.bash_profile"
fi
if ! grep -Fqx "$profile_marker" "$HOME/.bash_profile" 2>/dev/null; then
    cat >> "$HOME/.bash_profile" <<'EOF'

# django-language-server toolchain
if [ -f "$HOME/.cargo/env" ]; then
    . "$HOME/.cargo/env"
fi
export PATH="$HOME/.local/bin:$PATH"
EOF
fi
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

if ! command -v rustup >/dev/null 2>&1; then
    echo "==> Installing rustup"
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs |
        sh -s -- -y --profile minimal --no-modify-path
fi

echo "==> Installing Rust toolchains and components"
rust_channel="$(sed -n 's/^channel = "\(.*\)"/\1/p' rust-toolchain.toml)"
rustfmt_channel="$(sed -n 's/^channel = "\(.*\)"/\1/p' tools/rustfmt/rust-toolchain.toml)"
hawk_channel="$(sed -n 's/^channel = "\(.*\)"/\1/p' tools/hawk/rust-toolchain.toml)"
if [[ -z "$rust_channel" || -z "$rustfmt_channel" || -z "$hawk_channel" ]]; then
    echo "Unable to read a pinned Rust toolchain channel" >&2
    exit 1
fi
rustup toolchain install "$rust_channel" --profile minimal --component clippy
# Formatting uses its pinned nightly; Hawk uses its compiler-private toolchain.
rustup toolchain install "$rustfmt_channel" --profile minimal --component rustfmt
if [[ "$hawk_channel" != "$rust_channel" ]]; then
    rustup toolchain install "$hawk_channel" --profile minimal
fi

if ! command -v uv >/dev/null 2>&1; then
    echo "==> Installing uv"
    curl -LsSf https://astral.sh/uv/install.sh |
        env UV_INSTALL_DIR="$HOME/.local/bin" sh
fi

if [[ ! -x "$HOME/.local/bin/just" ]]; then
    echo "==> Installing just"
    curl --proto '=https' --tlsv1.2 -sSf https://just.systems/install.sh |
        bash -s -- --tag 1.57.0 --to "$HOME/.local/bin"
fi

if [[ "$(cargo hawk --version 2>/dev/null || true)" != "cargo hawk 0.1.9" ]]; then
    echo "==> Installing cargo-hawk"
    curl --proto '=https' --tlsv1.2 -LsSf \
        https://github.com/astral-sh/hawk/releases/download/0.1.9/cargo-hawk-installer.sh | sh
fi

if [[ "$(cargo insta --version 2>/dev/null || true)" != "cargo-insta 1.48.0" ]]; then
    echo "==> Installing cargo-insta"
    curl --proto '=https' --tlsv1.2 -LsSf \
        https://github.com/mitsuhiko/insta/releases/download/1.48.0/cargo-insta-installer.sh |
        env CARGO_INSTA_NO_MODIFY_PATH=1 sh
fi

echo "==> Installing locked Python dependencies"
uv sync --frozen --no-install-project

echo "==> Fetching locked Rust dependencies"
cargo fetch --locked

if ! command -v prek >/dev/null 2>&1; then
    echo "==> Installing prek"
    uv tool install prek
fi

echo "==> Installing pre-commit hooks"
hooks_path="$(git config --path core.hooksPath || true)"
if [[ -n "$hooks_path" && "$hooks_path" == /* && "$(basename "$hooks_path")" == hooks ]]; then
    # Amp uses a global hooks directory for its prepare-commit-msg hook. Install
    # prek alongside it instead of replacing the directory at repository scope.
    prek install --git-dir "$(dirname "$hooks_path")" --prepare-hooks
else
    prek install --prepare-hooks
fi

echo "==> Syncing the locked test corpus"
just corpus sync

echo "==> Setup complete"
